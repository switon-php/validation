{
  "name": "switon/validation",
  "description": "Validation rules, constraints, and error collection for Switon Framework",
  "type": "library",
  "keywords": [
    "switon",
    "validation",
    "constraints",
    "validator"
  ],
  "homepage": "https://github.com/switon-php/validation",
  "license": "MIT",
  "authors": [
    {
      "name": "switon",
      "email": "admin@switon.dev"
    }
  ],
  "support": {
    "source": "https://github.com/switon-php/validation",
    "issues": "https://github.com/switon-php/validation/issues",
    "docs": "https://docs.switon.dev/latest/validation"
  },
  "require": {
    "php": ">=8.3",
    "switon/core": "^1.0"
  },
  "require-dev": {
    "switon/testing": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "switon/composer-extra": true
    }
  },
  "autoload": {
    "psr-4": {
      "Switon\\Validating\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Switon\\Validating\\Tests\\": "tests/"
    }
  },
  "extra": {
    "switon": {
      "providers": [
        "Switon\\Validating\\ServiceProvider"
      ]
    }
  }
}
